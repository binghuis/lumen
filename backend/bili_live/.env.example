# 复制为 .env 填好后,用环境变量加载:
#   set -a && source .env && set +a && uv run python receiver.py
# (receiver.py 直接读 os.environ,.env 不会自动加载,需先 export)

# ---- 模式选择 ----
# web       : 审核前先跑通,只需 BILI_ROOM_ID(+可选 SESSDATA)
# open_live : 审核通过后正式用,需下面 4 个开放平台凭据
LUMEN_BILI_MODE=web

# ---- web 模式 ----
# 直播间 URL 末尾的数字
BILI_ROOM_ID=
# 已登录账号 Cookie 里的 SESSDATA。不填弹幕文本照样能收,只是用户名打码(如 正***)、UID 为 0;要完整用户名才需填
BILI_SESSDATA=

# ---- 发弹幕闭环 auto_reply.py(mode A,AI 当弹幕机器人)----
# bili_jct:和 SESSDATA 同一个 Cookie 面板里复制,发弹幕的 CSRF。仅 auto_reply.py 需要
BILI_BILI_JCT=
# 两条回复最短间隔(秒),防被限流/封号,建议别调太低
REPLY_MIN_INTERVAL=5

# ---- 语音回复 live_vtuber.py(mode B:大模型 + TTS 语音播报)----
# 火山豆包(方舟 Ark,OpenAI 兼容)
ARK_API_KEY=
ARK_MODEL=                                   # 推理接入点 ID,方舟控制台拿
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# edge-tts 音色(免费免 key),女声默认;可换 zh-CN-YunxiNeural 等
TTS_VOICE=zh-CN-XiaoxiaoNeural
# 说话时最多积压几条弹幕,满了丢弃保新鲜
VTUBER_QUEUE_MAX=2

# ---- open_live 模式(open-live.bilibili.com 审核通过后填)----
# 开发者入驻通过后,【个人资料】里拿
BILI_ACCESS_KEY_ID=
BILI_ACCESS_KEY_SECRET=
# 【我的项目】创建「互动玩法」项目后的项目ID
BILI_APP_ID=
# 主播在「开播设置」生成的身份码
BILI_ROOM_OWNER_AUTH_CODE=
